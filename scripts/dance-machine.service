[Unit]
Description=Fitness Center Dance Machine Kiosk
After=network.target sound.target

[Service]
Type=simple
User=root
WorkingDirectory=/app
ExecStart=/usr/bin/bash scripts/kiosk-standalone.sh
Restart=always
RestartSec=5

# v3.1.0 Industrial Process Scheduling
CPUSchedulingPolicy=rr
CPUSchedulingPriority=99
Nice=-20
IOSchedulingClass=realtime
IOSchedulingPriority=0

[Install]
WantedBy=multi-user.target
